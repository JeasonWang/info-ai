# 本文件是配置模板，不要写入真实密码或 Cookie 后提交。

# 本地开发默认直接连接本机 MySQL 3306；上线阶段由 docker-compose 注入容器内 MySQL 配置。
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=info-max

# info-aggregation 配置
DB_HOST=127.0.0.1
DB_TYPE=mysql
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=info-max
LOG_LEVEL=INFO
TZ=Asia/Shanghai
APP_TIMEZONE=Asia/Shanghai
CRAWLER_MAX_CONTENT_LENGTH=12000
ENABLE_PUBLIC_API=1
ENABLE_SEED_DATA=false
REBUILD_EVENTS_ON_STARTUP=false

# 事件分析配置。默认使用规则兜底；本地部署千问后可开启 LLM 增强。
EVENT_ANALYSIS_MODE=hybrid
EVENT_ANALYSIS_ENABLE_LLM=0
EVENT_ANALYSIS_PROVIDER=openai_compatible
EVENT_ANALYSIS_BASE_URL=http://127.0.0.1:8001/v1
EVENT_ANALYSIS_API_KEY=
EVENT_ANALYSIS_MODEL=qwen2.5-14b-instruct
EVENT_ANALYSIS_TIMEOUT=60
EVENT_ANALYSIS_MAX_INPUT_CHARS=12000
EVENT_ANALYSIS_TEMPERATURE=0.2
EVENT_ANALYSIS_FALLBACK_TO_RULE=1
EVENT_ANALYSIS_LLM_RETRY_TIMES=2
EVENT_ANALYSIS_LLM_FAILURE_THRESHOLD=3
EVENT_ANALYSIS_LLM_COOLDOWN_MINUTES=30

# Go 业务 API info-serve 配置
INFO_SERVE_MYSQL_DSN=root:change-me@tcp(127.0.0.1:3306)/info-max?charset=utf8mb4&parseTime=true&loc=Local
INFO_SERVE_SESSION_SECRET=change-me
INFO_AGGREGATION_BASE_URL=http://127.0.0.1:8000
AGGREGATION_HTTP_BASE_URL=http://127.0.0.1:8000
AGGREGATION_LLM_TIMEOUT_MS=240000
AGGREGATION_RESULT_PREFIX=info_ai:aggregation:results:
AGGREGATION_RESULT_WAIT_MS=5000
# 默认管理员账号
INFO_ADMIN_EMAIL=admin@info-daren.local
INFO_ADMIN_PASSWORD=change-me

# 前端统一 API 入口。生产 Docker 默认同源 /api，经由前端容器 Nginx 代理到 info-serve。
VITE_API_BASE_URL=/api

# 渠道登录态 Cookie / ZSE 已迁移到数据库 channel.cookies 和 channel.extra_credentials。
# 请在管理后台“凭证管理”维护，不再通过 .env 配置。
